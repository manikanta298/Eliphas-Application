# ─── LOCAL DEVELOPMENT ─────────────────────────────────────────
# Leave this empty in local dev — the Vite proxy handles /api → localhost:5000
# VITE_API_URL=

# ─── PRODUCTION (Vercel / Netlify) ─────────────────────────────
# Set this to your Render backend URL (no trailing slash)
# Example:
# VITE_API_URL=https://logicore-erp-api.onrender.com
