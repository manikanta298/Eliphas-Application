# ─── SERVER ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MONGODB ───────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers → Copy URI
# Replace <username>, <password>, <cluster> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/logistics-erp?retryWrites=true&w=majority

# ─── JWT SECRETS ───────────────────────────────────────────────
# Use any long random strings — keep them secret!
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── FRONTEND URL (for CORS) ───────────────────────────────────
# Local dev: http://localhost:5173
# Production: your Vercel/Netlify URL — no trailing slash
FRONTEND_URL=http://localhost:5173
